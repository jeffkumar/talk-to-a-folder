#!/usr/bin/env sh

# Get list of staged TypeScript/JavaScript files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "✅ No staged TS/JS files to lint"
  exit 0
fi

echo "🔍 Linting staged files..."

# Run Biome check only on staged files
if ! npx biome check --no-errors-on-unmatched $STAGED_FILES; then
  echo ""
  echo "❌ Lint errors found in staged files. Fix them before committing."
  echo "   Run 'pnpm format' to auto-fix, or fix manually."
  exit 1
fi

echo "✅ Lint passed"
