# =============================================================================
# Talk to a Folder - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================


# =============================================================================
# REQUIRED - Core Infrastructure
# =============================================================================

# NextAuth.js session encryption key
# Generate: openssl rand -base64 32
AUTH_SECRET=

# PostgreSQL connection string
# Get from: https://neon.tech or https://vercel.com/docs/postgres
POSTGRES_URL=

# Vercel Blob storage for file uploads
# Get from: https://vercel.com/docs/blob
BLOB_READ_WRITE_TOKEN=


# =============================================================================
# REQUIRED - AI Providers
# =============================================================================

# Anthropic API key - Primary LLM provider for chat (Claude)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API key - Used for embeddings and fallback inference
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Turbopuffer API key - Vector database for document search/RAG
# Get from: https://turbopuffer.com
TURBOPUFFER_API_KEY=

# Turbopuffer namespace - Isolates your vectors (e.g., per environment)
# Leave commented to use default, or set a custom namespace
# TURBOPUFFER_NAMESPACE=my_project_v1


# =============================================================================
# REQUIRED - Google Drive Integration
# =============================================================================
# To enable Google Drive, you need to create a Google Cloud project and
# configure OAuth. See README.md for detailed setup instructions.

# OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Google Picker API (for client-side file picker)
# NEXT_PUBLIC_GOOGLE_APP_ID is your Google Cloud Project Number
# NEXT_PUBLIC_GOOGLE_API_KEY is a browser API key restricted to Picker API
NEXT_PUBLIC_GOOGLE_APP_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=


# =============================================================================
# REQUIRED - Document Parsing (Reducto)
# =============================================================================

# Reducto API key for advanced PDF and document parsing
# Get from: https://reducto.ai
REDUCTO_API_KEY=


# =============================================================================
# REQUIRED - Local Database
# =============================================================================

# Use a local PostgreSQL database instead of POSTGRES_URL
# Set to "true" to use local, "false" to use POSTGRES_URL
USE_LOCAL_DB=false
LOCAL_POSTGRES_URL=postgresql://localhost:5432/flowchat

# Database connection pool settings
POSTGRES_MAX_CONNECTIONS=5
POSTGRES_CONNECT_TIMEOUT_SECONDS=30


# =============================================================================
# REQUIRED - Debug & Feature Flags
# =============================================================================

# Verbose logging for various subsystems (set to 1 to enable)
DEBUG_TURBOPUFFER=0
DEBUG_FINANCE_AGENT_CHAT=0
DEBUG_PROJECT_AGENT_CHAT=0
DEBUG_CITATIONS_AGENT_CHAT=0

# Prevent duplicate document filenames within a project
PREVENT_DUPLICATE_PROJECT_DOC_FILENAMES=true


# =============================================================================
# OPTIONAL - Additional Inference Providers
# =============================================================================

# Baseten API key - Alternative inference and embeddings provider
# Get from: https://baseten.co → Dashboard → API Keys
# BASETEN_API_KEY=

# GLM API key - ZhipuAI models
# Get from: https://open.bigmodel.cn/
# GLM_API_KEY=

# Embeddings provider selection: "openai", "baseten", or "auto"
# - openai: Use OpenAI embeddings (requires OPENAI_API_KEY)
# - baseten: Use Baseten embeddings (requires BASETEN_API_KEY)
# - auto: Use Baseten if BASETEN_API_KEY is set, otherwise OpenAI
# WARNING: Don't mix providers in the same namespace - re-ingest if switching
# EMBEDDINGS_PROVIDER=openai

# Use OpenAI for chat inference instead of Anthropic
# USE_OPENAI_INFERENCE=false


# =============================================================================
# OPTIONAL - Microsoft SharePoint Integration
# =============================================================================
# Create an app registration in Azure Portal to enable SharePoint access.

# MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# MICROSOFT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/microsoft/callback


# =============================================================================
# OPTIONAL - Email (Resend)
# =============================================================================

# Resend API key for transactional emails
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=

# Override default sender and contact email addresses
# FROM_EMAIL=Your App <noreply@yourdomain.com>
# CONTACT_EMAIL=support@yourdomain.com


# =============================================================================
# OPTIONAL - Security
# =============================================================================

# Encryption key for storing OAuth tokens at rest
# Generate: openssl rand -base64 32
# INTEGRATIONS_TOKEN_ENCRYPTION_KEY=
