# ============================================================================
# REQUIRED — Core
# ============================================================================

# NextAuth secret. Generate one: https://generate-secret.vercel.app/32
# or run: openssl rand -base64 32
AUTH_SECRET=

# PostgreSQL connection string
# Vercel Postgres: https://vercel.com/docs/postgres
POSTGRES_URL=

# Vercel Blob storage for file uploads
# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=

# ============================================================================
# REQUIRED — AI & Embeddings
# ============================================================================

# At least one LLM provider is required.
# Anthropic is the primary provider used for chat.
ANTHROPIC_API_KEY=

# OpenAI is used as a fallback and for embeddings (when EMBEDDINGS_PROVIDER=openai).
OPENAI_API_KEY=

# Turbopuffer vector database for RAG / document search
# https://turbopuffer.com
TURBOPUFFER_API_KEY=

# Turbopuffer namespace (defaults to a per-environment value if unset)
# TURBOPUFFER_NAMESPACE=

# Which provider to use for embeddings: "openai" or "baseten"
# EMBEDDINGS_PROVIDER=openai

# ============================================================================
# OPTIONAL — Additional LLM Providers
# ============================================================================

# Baseten (used as alternative inference + embeddings provider)
# BASETEN_API_KEY=

# GLM (ZhipuAI)
# GLM_API_KEY=

# Vercel AI Gateway — required for non-Vercel deployments;
# on Vercel, OIDC tokens are used automatically.
# https://vercel.com/ai-gateway
# AI_GATEWAY_API_KEY=

# ============================================================================
# OPTIONAL — Email (Resend)
# ============================================================================

# Resend API key for transactional emails (password reset, invitations, etc.)
# https://resend.com/api-keys
# RESEND_API_KEY=

# Override the default "from" address and contact email
# FROM_EMAIL=Flowchat <noreply@adventureflow.ai>
# CONTACT_EMAIL=jeff@adventureflow.ai

# ============================================================================
# OPTIONAL — Document Parsing (Reducto)
# ============================================================================

# Reducto API key for advanced document parsing (PDFs, etc.)
# https://reducto.ai
# REDUCTO_API_KEY=

# ============================================================================
# OPTIONAL — Redis
# ============================================================================

# Redis URL for caching / rate limiting
# https://vercel.com/docs/redis
# REDIS_URL=

# ============================================================================
# OPTIONAL — Integration: Google Drive
# ============================================================================

# OAuth credentials from Google Cloud Console
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Google Picker API key (browser key) and Cloud project number
# Used by the client-side Google file picker
# NEXT_PUBLIC_GOOGLE_API_KEY=
# NEXT_PUBLIC_GOOGLE_APP_ID=

# ============================================================================
# OPTIONAL — Security
# ============================================================================

# 32-byte base64 key for encrypting integration tokens at rest.
# Generate: openssl rand -base64 32
# INTEGRATIONS_TOKEN_ENCRYPTION_KEY=

# ============================================================================
# OPTIONAL — Feature Flags
# ============================================================================

# Use OpenAI for chat inference instead of the default provider
# USE_OPENAI_INFERENCE=false

# Prevent duplicate document filenames within a project (default: true)
# PREVENT_DUPLICATE_PROJECT_DOC_FILENAMES=true

# ============================================================================
# LOCAL DEVELOPMENT
# ============================================================================

# Use a local PostgreSQL database instead of POSTGRES_URL
# USE_LOCAL_DB=false
# LOCAL_POSTGRES_URL=postgresql://localhost:5432/flowchat

# Tune database connection pool
# POSTGRES_MAX_CONNECTIONS=5
# POSTGRES_CONNECT_TIMEOUT_SECONDS=

# ============================================================================
# DEBUG FLAGS (development only)
# ============================================================================

# DEBUG_TURBOPUFFER=0
# DEBUG_FINANCE_AGENT_CHAT=0
# DEBUG_PROJECT_AGENT_CHAT=0
# DEBUG_CITATIONS_AGENT_CHAT=0
# RETRIEVAL_TIME_FILTER_MODE=
# RETRIEVAL_ROW_TIMESTAMP_PROJECT_IDS=
